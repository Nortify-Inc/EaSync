{
  "heated_floors": [
    {
      "brand": "Warmup",
      "model": "6iE Smart WiFi Thermostat",
      "capabilities": ["power", "temperature", "mode", "schedule"],
      "payloads": {
        "power": { "topic": "device/{uuid}/set", "template": { "power": "{value}" } },
        "temperature": { "topic": "device/{uuid}/set", "template": { "temperature": "{value}" } },
        "mode": { "topic": "device/{uuid}/set", "template": { "mode": "{value}" } },
        "schedule": { "topic": "device/{uuid}/set", "template": { "schedule": "{value}" } }
      },
      "constrains": {
        "power": true,
        "temperature": { "min": 5, "max": 35 },
        "mode": ["manual", "auto"]
      }
    },
