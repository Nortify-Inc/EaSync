{
  "lamps": [
    {
      "brand": "Philips",
      "model": "Hue White and Color Ambiance E27",
      "protocol": "zigbee",
      "capabilities": ["power", "brightness", "color", "colorTemperature"],
      "payloads": {
        "power": { "topic": "device/{uuid}/set", "template": { "power": "{value}" } },
        "brightness": { "topic": "device/{uuid}/set", "template": { "brightness": "{value}" } },
        "color": { "topic": "device/{uuid}/set", "template": { "color": "{value}" } },
        "colorTemperature": { "topic": "device/{uuid}/set", "template": { "colorTemperature": "{value}" } }
      },
      "constrains": {
        "power": true,
        "brightness": { "min": 1, "max": 254 },
        "color": { "type": "hs" },
        "colorTemperature": { "min": 153, "max": 500 }
      }
    },
