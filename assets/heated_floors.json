{
  "heated_floors": [
    {
      "brand": "Warmup",
      "model": "6iE Smart WiFi Thermostat",
      "protocol": "wifi",
      "capabilities": ["power", "temperature", "mode", "time"],
      "payloads": {
        "power": { "topic": "device/{uuid}/set", "template": { "power": "{value}" } },
        "temperature": { "topic": "device/{uuid}/set", "template": { "temperature": "{value}" } },
        "mode": { "topic": "device/{uuid}/set", "template": { "mode": "{value}" } },
        "time": { "topic": "device/{uuid}/set", "template": { "schedule": "{value}" } }
      },
      "constrains": {
        "power": true,
        "temperature": { "min": 5, "max": 32, "step": 0.5 },
        "mode": ["manual", "auto"]
      }
    },
