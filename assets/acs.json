{
  "acs": [
    {
      "brand": "Daikin",
      "model": "FTXM35R",
      "protocol": "wifi",
      "capabilities": ["power", "temperature", "mode"],
      "payloads": {
        "power": { "topic": "daikin/{uuid}/set", "template": { "power": "{value}" } },
        "temperature": { "topic": "daikin/{uuid}/set", "template": { "temperature": "{value}" } },
        "mode": { "topic": "daikin/{uuid}/set", "template": { "mode": "{value}" } }
      },
      "constrains": {
        "power": true,
        "temperature": { "min": 16, "max": 30, "step": 0.5 },
        "mode": ["cool", "heat", "dry", "fan", "auto"]
      }
    },
