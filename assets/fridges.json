{
  "fridges": [
    {
      "brand": "Midea",
      "model": "Side by Side 442L",
      "protocol": "wifi",
      "capabilities": ["power", "temperature_fridge", "temperature_freezer", "mode"],
      "payloads": {
        "power": {
          "topic": "device/{uuid}/set",
          "template": { "power": "{value}" }
        },
        "temperature_fridge": {
          "topic": "device/{uuid}/set",
          "template": { "temperature_fridge": "{value}" }
        },
        "temperature_freezer": {
          "topic": "device/{uuid}/set",
          "template": { "temperature_freezer": "{value}" }
        },
        "mode": {
          "topic": "device/{uuid}/set",
          "template": { "mode": "{value}" }
        }
      },
      "constrains": {
        "power": true,
        "temperature_fridge": { "min": 2, "max": 8, "step": 0.5 },
        "temperature_freezer": { "min": -24, "max": -15, "step": 0.5 },
        "mode": ["normal", "eco", "super_freeze"]
      }
    },

